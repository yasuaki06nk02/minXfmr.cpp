# Ignore build artifacts
/build/

# Visual Studio
.vs/
*.vcxproj.user
*.suo
*.user
*.userosscache
*.sln.docstates

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake

# Compiled object files and binaries
*.obj
*.o
*.lo
*.a
*.lib
*.dll
*.so
*.dylib
*.exe
*.pdb
*.ilk
*.idb

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/
pip-wheel-metadata/
*.egg-info/
.python-version

# Models and large binaries
*.gguf
*.safetensors
*.pt
*.pth
*.bin
*.onnx
*.ckpt
*.h5
*.npz
*.tar
*.tar.gz
*.tgz

# Logs and search artifacts
*.log
*.err
std*.txt
run.log
run.err
stderr.txt
stdout.txt
stdin.txt
chat_debug*.log
scripts/transpose_search_logs/
transpose_search_logs/

# IDEs and editors
.vscode/
.idea/
*.code-workspace

# OS files
Thumbs.db
desktop.ini
.DS_Store

# Temporary and swap files
*.tmp
*.temp
*.swp
*~
*.bak

# Secrets
.env
.env.local
*.pem
*.key

# Keep .gitattributes tracked (do not ignore)

# Ignore .out artifacts produced by scripts/tests
*.out

# Ignore result mask JSON logs generated during experiments
result_mask*.json